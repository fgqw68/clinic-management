# ========================================
# KadeejaClinic Bot Environment Configuration
# ========================================

# Telegram Bot Configuration
# Get this from @BotFather on Telegram
# Steps:
# 1. Start a chat with @BotFather
# 2. Send /newbot
# 3. Follow the prompts to create your bot
# 4. Copy the token provided
BOT_TOKEN=your_telegram_bot_token_here

# Supabase Configuration
# Get these from your Supabase project settings
# Steps:
# 1. Go to https://supabase.com
# 2. Create a new project or select existing
# 3. Go to Project Settings > API
# 4. Copy the Project URL and anon/public API key
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# ========================================
# Staff Configuration (staff_config.py)
# ========================================
# After getting Telegram Chat IDs from @userinfobot:
# 1. Edit staff_config.py
# 2. Add admin chat IDs to "admin_chat_ids"
# 3. Add staff chat IDs to "staff_chat_ids"
# 4. Map chat IDs to roles in "staff_roles"

 